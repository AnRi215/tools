function Show-ScanProgress([string]$Root, [string]$CurrentItem, [int]$Done, [int]$Total) {
    $W    = [math]::Max(40, [Console]::WindowWidth)
    $H    = [math]::Max(10, [Console]::WindowHeight)
    $bW   = [math]::Min(48, $W - 10)
    $pct  = if ($Total -gt 0) { [int](($Done / $Total) * 100) } else { 0 }
    $fil  = [int]($bW * $pct / 100)

    $contentH = 8
    $y    = [math]::Max(2, 1 + [int](($H - 1 - $contentH) / 2))
    $blockW = $bW + 8
    $xOff   = [math]::Max(2, [int](($W - $blockW) / 2))
    $textW  = $W - $xOff - 2

    Clear-Console

    [Console]::SetCursorPosition(0, 0)
    [Console]::BackgroundColor = "DarkCyan"; [Console]::ForegroundColor = "White"
    Write-Host ("  ncdu for windows  ~  Scanne ...").PadRight($W).Substring(0, $W) -NoNewline
    [Console]::BackgroundColor = "Black"

    [Console]::SetCursorPosition($xOff, $y)
    [Console]::ForegroundColor = "DarkGray"; Write-Host "Verzeichnis:"
    [Console]::SetCursorPosition($xOff, $y + 1)
    [Console]::ForegroundColor = "White"
    $rd = if ($Root.Length -gt $textW) { "..." + $Root.Substring($Root.Length - ($textW - 3)) } else { $Root }
    Write-Host $rd.PadRight($textW).Substring(0, $textW)

    [Console]::SetCursorPosition($xOff, $y + 3)
    [Console]::ForegroundColor = "DarkGray"; Write-Host "Scanne:"
    [Console]::SetCursorPosition($xOff, $y + 4)
    [Console]::ForegroundColor = "Cyan"
    $cd = if ($CurrentItem.Length -gt $textW) { "..." + $CurrentItem.Substring($CurrentItem.Length - ($textW - 3)) } else { $CurrentItem }
    Write-Host $cd.PadRight($textW).Substring(0, $textW)

    [Console]::SetCursorPosition($xOff, $y + 6)
    [Console]::ForegroundColor = "DarkGray";  Write-Host "[" -NoNewline
    [Console]::ForegroundColor = "Green";     Write-Host ("X" * $fil) -NoNewline
    [Console]::ForegroundColor = "DarkGray";  Write-Host (("." * ($bW - $fil)) + "]  ") -NoNewline
    [Console]::ForegroundColor = "Yellow";    Write-Host "$pct%"

    [Console]::SetCursorPosition($xOff, $y + 7)
    [Console]::ForegroundColor = "DarkGray"; Write-Host "$Done / $Total Elemente"
}

function Load-Dir([string]$Path) {
    $allDirs  = @(Get-ChildItem $Path -Directory -Force -ErrorAction SilentlyContinue)
    $allFiles = @(Get-ChildItem $Path -File      -Force -ErrorAction SilentlyContinue)
    $total    = $allDirs.Count + $allFiles.Count
    $done     = 0
    $list     = New-Object System.Collections.Generic.List[psobject]

    foreach ($d in $allDirs) {
        Show-ScanProgress -Root $Path -CurrentItem $d.FullName -Done $done -Total $total
        $list.Add([pscustomobject]@{ Name=$d.Name; Path=$d.FullName; Size=(Get-DirSize $d.FullName); IsDir=$true })
        $done++
    }
    foreach ($f in $allFiles) {
        Show-ScanProgress -Root $Path -CurrentItem $f.FullName -Done $done -Total $total
        $list.Add([pscustomobject]@{ Name=$f.Name; Path=$f.FullName; Size=$f.Length; IsDir=$false })
        $done++
    }
    return @($list | Sort-Object -Property Size -Descending)
}

