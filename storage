function Render([string]$CurPath, [array]$Items, [int]$Sel, [int]$Scroll, [int]$Depth) {
    $W      = [math]::Max(40, [Console]::WindowWidth)
    $H      = [math]::Max(10, [Console]::WindowHeight)
    $listH  = $H - 3
    $barW   = 20; $sizeW = 9
    $fixedW = 1+$sizeW+2+$barW+2+1
    $nameW  = [math]::Max(4, $W-$fixedW)
    $maxS   = if ($Items.Count -gt 0) { [long]($Items|Measure-Object -Property Size -Maximum).Maximum } else { 1L }
    $totS   = if ($Items.Count -gt 0) { [long]($Items|Measure-Object -Property Size -Sum).Sum }    else { 0L }

    [Console]::SetCursorPosition(0,0)
    [Console]::BackgroundColor = "DarkCyan"; [Console]::ForegroundColor = "White"
    Write-Host ("  ncdu for windows  ~  [Leertaste] Menü   Enter/→ Öffnen   ← Zurück   Home/End   q Beenden").PadRight($W).Substring(0,$W) -NoNewline

    [Console]::BackgroundColor = "Black"; [Console]::ForegroundColor = "DarkCyan"
    [Console]::SetCursorPosition(0,1)
    $pb = " $CurPath "+("-"*[math]::Max(0,$W-$CurPath.Length-3))
    Write-Host $pb.Substring(0,[math]::Min($pb.Length,$W)).PadRight($W) -NoNewline

    for ($i=0; $i -lt $listH; $i++) {
        [Console]::SetCursorPosition(0,$i+2)
        $idx=$i+$Scroll
        if ($idx -ge $Items.Count) {
            [Console]::BackgroundColor="Black"; [Console]::ForegroundColor="Black"
            Write-Host (" "*$W) -NoNewline; continue
        }
        $it=$Items[$idx]; $isSel=($idx -eq $Sel)
        $sz=Format-Bytes $it.Size; $bar=Make-Bar $it.Size $maxS $barW
        $pfx=if($it.IsDir){"/"}else{" "}; $nm=Trunc ($pfx+$it.Name) $nameW

        if ($isSel) {
            [Console]::BackgroundColor="DarkGreen"; [Console]::ForegroundColor="White"
            Write-Host (" $sz [$bar] $nm").PadRight($W).Substring(0,$W) -NoNewline
        } else {
            [Console]::BackgroundColor="Black"
            Write-Host " " -NoNewline
            [Console]::ForegroundColor="Yellow";   Write-Host $sz   -NoNewline
            [Console]::ForegroundColor="DarkGray"; Write-Host " [" -NoNewline
            [Console]::ForegroundColor="Green";    Write-Host $bar  -NoNewline
            [Console]::ForegroundColor="DarkGray"; Write-Host "] " -NoNewline
            [Console]::ForegroundColor="Cyan";     Write-Host $nm   -NoNewline
        }
    }

    [Console]::BackgroundColor="DarkCyan"; [Console]::ForegroundColor="White"
    [Console]::SetCursorPosition(0,$H-1)
    $selSz=if($Items.Count-gt 0){Format-Bytes $Items[$Sel].Size}else{"  ---  "}
    Write-Host ("  Total: $(Format-Bytes $totS)   Items: $($Items.Count)   Ausgewählt: $selSz   Tiefe: $Depth").PadRight($W).Substring(0,$W) -NoNewline
}

# ═══════════════════════════════════════════════════════════════════════════════
#  MAIN
# ═══════════════════════════════════════════════════════════════════════════════

$origFg=[Console]::ForegroundColor; $origBg=[Console]::BackgroundColor
[Console]::CursorVisible=$false

$navStack=New-Object System.Collections.Stack; $depth=0
$curPath=$Root; $items=Load-Dir $curPath; $sel=0; $scroll=0; $running=$true

try {
    while ($running) {
        $listH=[math]::Max(1,[Console]::WindowHeight-3)
        Render $curPath $items $sel $scroll $depth
        $k=[Console]::ReadKey($true); $ks=$k.Key.ToString()

        if ($ks -eq "UpArrow") {
            if ($sel -gt 0) { $sel--; if ($sel -lt $scroll) { $scroll = $sel } }
            # Buffer leeren: alle bereits gepufferten UpArrow-Events auf einmal verarbeiten
            while ([Console]::KeyAvailable) {
                if ([Console]::ReadKey($true).Key.ToString() -ne "UpArrow") { break }
                if ($sel -gt 0) { $sel--; if ($sel -lt $scroll) { $scroll = $sel } }
            }
        } elseif ($ks -eq "DownArrow") {
            if ($sel -lt ($items.Count-1)) { $sel++; if ($sel -ge ($scroll+$listH)) { $scroll=$sel-$listH+1 } }
            # Buffer leeren: alle bereits gepufferten DownArrow-Events auf einmal verarbeiten
            while ([Console]::KeyAvailable) {
                if ([Console]::ReadKey($true).Key.ToString() -ne "DownArrow") { break }
                if ($sel -lt ($items.Count-1)) { $sel++; if ($sel -ge ($scroll+$listH)) { $scroll=$sel-$listH+1 } }
            }
        }
        elseif ($ks -eq "Home")      { $sel=0; $scroll=0 }
        elseif ($ks -eq "End")       { $sel=[math]::Max(0,$items.Count-1); $scroll=[math]::Max(0,$sel-$listH+1) }
        elseif ($ks -eq "Enter" -or $ks -eq "RightArrow") {
            if ($items.Count-gt 0 -and $items[$sel].IsDir) {
                $navStack.Push(@{Path=$curPath;Items=$items;Sel=$sel;Scroll=$scroll}); $depth++
                $curPath=$items[$sel].Path; $items=Load-Dir $curPath; $sel=0; $scroll=0
            }
        }
        elseif ($ks -eq "LeftArrow") {
            if ($navStack.Count-gt 0) {
                $p=$navStack.Pop(); $depth--; $curPath=$p.Path; $items=$p.Items; $sel=$p.Sel; $scroll=$p.Scroll
            } else {
                $parent=Split-Path $curPath -Parent
                if ($parent -and ($parent-ne $curPath) -and (Test-Path $parent)) {
                    $navStack.Push(@{Path=$curPath;Items=$items;Sel=$sel;Scroll=$scroll}); $depth++
                    $curPath=$parent; $items=Load-Dir $curPath; $sel=0; $scroll=0
                }
            }
        }
        elseif ($ks -eq "Spacebar") {
            if ($items.Count-gt 0) {
                $action=Show-ContextMenu $items[$sel]; Clear-Console
                if ($action -eq "rename") {
                    $newName=Show-RenamePrompt $items[$sel].Name; Clear-Console
                    if ($newName -and $newName-ne $items[$sel].Name) {
                        try {
                            Rename-Item -Path $items[$sel].Path -NewName (Join-Path (Split-Path $items[$sel].Path -Parent) $newName) -Force -ErrorAction Stop
                            $items=Load-Dir $curPath; $sel=[math]::Min($sel,[math]::Max(0,$items.Count-1))
                        } catch { Show-Error "Fehler: $($_.Exception.Message)"; Clear-Console }
                    }
                } elseif ($action -eq "delete") {
                    $ok=Show-DeleteConfirm $items[$sel]; Clear-Console
                    if ($ok) {
                        try {
                            if($items[$sel].IsDir){Remove-Item $items[$sel].Path -Recurse -Force -EA Stop}
                            else{Remove-Item $items[$sel].Path -Force -EA Stop}
                            $items=Load-Dir $curPath
                            $sel=[math]::Min($sel,[math]::Max(0,$items.Count-1))
                            $scroll=[math]::Min($scroll,[math]::Max(0,$items.Count-$listH))
                        } catch { Show-Error "Fehler: $($_.Exception.Message)"; Clear-Console }
                    }
                }
            }
        }
        elseif ($ks -eq "Q" -or $ks -eq "Escape") { $running=$false }
    }
} finally {
    [Console]::CursorVisible=$true; [Console]::BackgroundColor=$origBg; [Console]::ForegroundColor=$origFg
    Clear-Console
    Write-Footer
}
