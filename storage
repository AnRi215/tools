function Show-ContextMenu([psobject]$Item) {
    $W       = [math]::Max(40, [Console]::WindowWidth)
    $H       = [math]::Max(10, [Console]::WindowHeight)
    $labels  = @("Umbenennen", "Löschen", "Abbrechen")
    $actions = @("rename", "delete", $null)
    $sel     = 0
    $bW      = 32
    $innerW  = $bW - 4          # fuer "| "..." |"-Zeilen
    $labelW  = $bW - 5          # fuer "|> "..." |" bzw. "|  "..." |"-Zeilen (3+content+2=bW => content=bW-5)
    $cx      = [int](($W - $bW) / 2)
    $cy      = [int](($H - ($labels.Count + 5)) / 2)

    while ($true) {
        [Console]::BackgroundColor = "DarkGray"; [Console]::ForegroundColor = "White"

        [Console]::SetCursorPosition($cx, $cy)
        Write-Host ("+" + ("-" * ($bW - 2)) + "+") -NoNewline

        $nm = if ($Item.Name.Length -gt $innerW) { $Item.Name.Substring(0, $innerW-3) + "..." } else { $Item.Name }
        [Console]::SetCursorPosition($cx, $cy+1)
        Write-Host ("| " + $nm.PadRight($innerW).Substring(0, $innerW) + " |") -NoNewline

        $meta = (Format-Bytes $Item.Size) + "  " + $(if ($Item.IsDir) { "Ordner" } else { "Datei" })
        [Console]::SetCursorPosition($cx, $cy+2)
        Write-Host ("| " + $meta.PadRight($innerW).Substring(0, $innerW) + " |") -NoNewline

        [Console]::SetCursorPosition($cx, $cy+3)
        Write-Host ("|" + ("-" * ($bW-2)) + "|") -NoNewline

        for ($i = 0; $i -lt $labels.Count; $i++) {
            [Console]::SetCursorPosition($cx, $cy+4+$i)
            $indicator = if ($i -eq $sel) { ">" } else { " " }
            if ($i -eq $sel) { [Console]::BackgroundColor = "DarkCyan" }
            else             { [Console]::BackgroundColor = "DarkGray" }
            [Console]::ForegroundColor = "White"
            # "|" + indicator(1) + " " + label(bW-5) + " |" = 1+1+1+(bW-5)+2 = bW
            Write-Host ("| " + $indicator + " " + $labels[$i].PadRight($labelW-1).Substring(0, $labelW-1) + " |") -NoNewline
        }

        [Console]::BackgroundColor = "DarkGray"; [Console]::ForegroundColor = "White"
        [Console]::SetCursorPosition($cx, $cy+4+$labels.Count)
        Write-Host ("+" + ("-" * ($bW-2)) + "+") -NoNewline

        $k  = [Console]::ReadKey($true); $ks = $k.Key.ToString()
        if     ($ks -eq "UpArrow")                                        { if ($sel -gt 0) { $sel-- } }
        elseif ($ks -eq "DownArrow")                                      { if ($sel -lt ($labels.Count-1)) { $sel++ } }
        elseif ($ks -eq "Enter")                                          { return $actions[$sel] }
        elseif ($ks -eq "Escape" -or $ks -eq "Spacebar" -or $ks -eq "Q") { return $null }
    }
}

function Show-RenamePrompt([string]$CurrentName) {
    $W      = [math]::Max(40, [Console]::WindowWidth)
    $H      = [math]::Max(10, [Console]::WindowHeight)
    $bW     = [math]::Min(60, $W - 4)
    $innerW = $bW - 4
    $cx     = [int](($W - $bW) / 2)
    $cy     = [int]($H / 2) - 4
    $inp    = $CurrentName
    $cur    = $inp.Length
    $scrollX = 0

    [Console]::CursorVisible = $true

    while ($true) {
        $vis = $innerW
        if ($cur -lt $scrollX)        { $scrollX = $cur }
        if ($cur -ge $scrollX + $vis) { $scrollX = $cur - $vis + 1 }
        $disp     = $inp.Substring($scrollX, [math]::Min($vis, [math]::Max(0, $inp.Length - $scrollX)))
        $curInBox = $cur - $scrollX

        [Console]::BackgroundColor = "DarkGray"; [Console]::ForegroundColor = "White"
        [Console]::SetCursorPosition($cx, $cy)
        Write-Host ("+" + ("-" * ($bW-2)) + "+") -NoNewline
        [Console]::SetCursorPosition($cx, $cy+1)
        Write-Host ("| " + "Umbenennen".PadRight($innerW).Substring(0,$innerW) + " |") -NoNewline
        [Console]::SetCursorPosition($cx, $cy+2)
        Write-Host ("|" + ("-" * ($bW-2)) + "|") -NoNewline

        [Console]::SetCursorPosition($cx, $cy+3)
        [Console]::BackgroundColor = "Black"; [Console]::ForegroundColor = "Cyan"
        Write-Host ("| " + $disp.PadRight($vis).Substring(0,$vis) + " |") -NoNewline

        [Console]::BackgroundColor = "DarkGray"; [Console]::ForegroundColor = "White"
        [Console]::SetCursorPosition($cx, $cy+4)
        Write-Host ("|" + ("-" * ($bW-2)) + "|") -NoNewline

        [Console]::SetCursorPosition($cx, $cy+5)
        [Console]::ForegroundColor = "DarkGray"
        # Kurzform damit kein Abschneiden am Rand
        $hint = " Enter: OK    Esc: Abbrechen    Pfeiltasten: Cursor"
        Write-Host ("| " + $hint.PadRight($innerW).Substring(0,$innerW) + " |") -NoNewline
        [Console]::ForegroundColor = "White"
        [Console]::SetCursorPosition($cx, $cy+6)
        Write-Host ("+" + ("-" * ($bW-2)) + "+") -NoNewline

        [Console]::SetCursorPosition($cx + 2 + $curInBox, $cy+3)

        $k  = [Console]::ReadKey($true); $ks = $k.Key.ToString()
        if     ($ks -eq "Enter")       { [Console]::CursorVisible = $false; return $inp }
        elseif ($ks -eq "Escape")      { [Console]::CursorVisible = $false; return $null }
        elseif ($ks -eq "LeftArrow")   { if ($cur -gt 0) { $cur-- } }
        elseif ($ks -eq "RightArrow")  { if ($cur -lt $inp.Length) { $cur++ } }
        elseif ($ks -eq "Home")        { $cur = 0 }
        elseif ($ks -eq "End")         { $cur = $inp.Length }
        elseif ($ks -eq "Backspace")   { if ($cur -gt 0) { $inp=$inp.Substring(0,$cur-1)+$inp.Substring($cur); $cur-- } }
        elseif ($ks -eq "Delete")      { if ($cur -lt $inp.Length) { $inp=$inp.Substring(0,$cur)+$inp.Substring($cur+1) } }
        else {
            $ch = $k.KeyChar
            if ($ch -ne [char]0 -and -not [char]::IsControl($ch)) { $inp=$inp.Substring(0,$cur)+$ch+$inp.Substring($cur); $cur++ }
        }
    }
}

function Show-DeleteConfirm([psobject]$Item) {
    $W      = [math]::Max(40, [Console]::WindowWidth)
    $H      = [math]::Max(10, [Console]::WindowHeight)
    $bW     = 52
    $innerW = $bW - 4
    $cx     = [int](($W - $bW) / 2)
    $cy     = [int]($H / 2) - 5
    $sel    = 0

    # Titel: "!" zentriert um "Löschen bestätigen"
    $titleCore = "Löschen bestätigen"
    $available = $innerW - $titleCore.Length - 2
    $lp        = [int]($available / 2)
    $rp        = $available - $lp
    $titleLine = "!" + (" " * $lp) + $titleCore + (" " * $rp) + "!"

    # Buttons - Basis: bW-2 (nur die zwei | Raender abziehen)
    $btnA    = "  Abbrechen   "   # 14
    $btnJ    = "  Ja, löschen  " # 16
    $btnGap  = 2
    $btnBase = $bW - 2            # 50 = Innenraum zwischen den | Zeichen
    $btnTot  = $btnA.Length + $btnGap + $btnJ.Length  # 32
    $btnLP   = [int](($btnBase - $btnTot) / 2)        # 9
    $btnRP   = $btnBase - $btnTot - $btnLP             # 9

    while ($true) {
        [Console]::BackgroundColor = "DarkYellow"; [Console]::ForegroundColor = "Black"

        [Console]::SetCursorPosition($cx, $cy)
        Write-Host ("+" + ("-" * ($bW-2)) + "+") -NoNewline
        [Console]::SetCursorPosition($cx, $cy+1)
        Write-Host ("| " + $titleLine.PadRight($innerW).Substring(0,$innerW) + " |") -NoNewline
        [Console]::SetCursorPosition($cx, $cy+2)
        Write-Host ("|" + ("-" * ($bW-2)) + "|") -NoNewline

        $nm = if ($Item.Name.Length -gt $innerW) { $Item.Name.Substring(0,$innerW-3)+"..." } else { $Item.Name }
        [Console]::SetCursorPosition($cx, $cy+3)
        Write-Host ("| " + $nm.PadRight($innerW).Substring(0,$innerW) + " |") -NoNewline
        $meta = (Format-Bytes $Item.Size) + "  " + $(if ($Item.IsDir) { "Ordner" } else { "Datei" })
        [Console]::SetCursorPosition($cx, $cy+4)
        Write-Host ("| " + $meta.PadRight($innerW).Substring(0,$innerW) + " |") -NoNewline
        [Console]::SetCursorPosition($cx, $cy+5)
        Write-Host ("|" + ("-" * ($bW-2)) + "|") -NoNewline
        [Console]::SetCursorPosition($cx, $cy+6)
        [Console]::ForegroundColor = "DarkGray"
        Write-Host ("| " + "Pfeiltasten: Auswählen   Enter: Bestätigen".PadRight($innerW).Substring(0,$innerW) + " |") -NoNewline
        [Console]::ForegroundColor = "Black"
        [Console]::SetCursorPosition($cx, $cy+7)
        Write-Host ("|" + ("-" * ($bW-2)) + "|") -NoNewline

        # Buttons (exakt bW Zeichen breit)
        [Console]::SetCursorPosition($cx, $cy+8)
        [Console]::BackgroundColor = "DarkYellow"; [Console]::ForegroundColor = "Black"
        Write-Host "|" -NoNewline
        Write-Host (" " * $btnLP) -NoNewline
        if ($sel -eq 0) { [Console]::BackgroundColor = "DarkGreen"; [Console]::ForegroundColor = "White" }
        else            { [Console]::BackgroundColor = "DarkGray";  [Console]::ForegroundColor = "Gray"  }
        Write-Host $btnA -NoNewline
        [Console]::BackgroundColor = "DarkYellow"; [Console]::ForegroundColor = "Black"
        Write-Host (" " * $btnGap) -NoNewline
        if ($sel -eq 1) { [Console]::BackgroundColor = "Red";       [Console]::ForegroundColor = "White" }
        else            { [Console]::BackgroundColor = "DarkGray";  [Console]::ForegroundColor = "Gray"  }
        Write-Host $btnJ -NoNewline
        [Console]::BackgroundColor = "DarkYellow"; [Console]::ForegroundColor = "Black"
        Write-Host ((" " * [math]::Max(0,$btnRP)) + "|") -NoNewline

        [Console]::SetCursorPosition($cx, $cy+9)
        Write-Host ("+" + ("-" * ($bW-2)) + "+") -NoNewline

        $k  = [Console]::ReadKey($true); $ks = $k.Key.ToString()
        if     ($ks -eq "LeftArrow" -or $ks -eq "RightArrow") { $sel = 1-$sel }
        elseif ($ks -eq "Enter")  { return ($sel -eq 1) }
        elseif ($ks -eq "Escape") { return $false }
    }
}

function Show-Error([string]$Msg) {
    $W  = [math]::Max(40, [Console]::WindowWidth)
    $H  = [math]::Max(10, [Console]::WindowHeight)
    $mW = [math]::Min(60, $W-4)
    $cx = [int](($W-$mW)/2)
    [Console]::SetCursorPosition($cx, [int]($H/2))
    [Console]::BackgroundColor = "DarkRed"; [Console]::ForegroundColor = "White"
    Write-Host ("  $Msg  ").PadRight($mW).Substring(0,$mW) -NoNewline
    Start-Sleep -Milliseconds 2000
}

