param([string]$Root = (Get-Location).Path)
 
Set-StrictMode -Off
$ErrorActionPreference = "SilentlyContinue"
 
# ═══════════════════════════════════════════════════════════════════════════════
#  HELPERS
# ═══════════════════════════════════════════════════════════════════════════════
 
function Get-DirSize([string]$Path) {
    try {
        $r = (Get-ChildItem $Path -Recurse -Force -EA SilentlyContinue |
              Where-Object { -not $_.PSIsContainer } |
              Measure-Object -Property Length -Sum).Sum
        if ($null -eq $r) { return 0L }
        return [long]$r
    } catch { return 0L }
}
 
function Format-Bytes([long]$B) {
    if ($B -ge 1TB) { return "{0,5:F1} TiB" -f ($B / 1TB) }
    if ($B -ge 1GB) { return "{0,5:F1} GiB" -f ($B / 1GB) }
    if ($B -ge 1MB) { return "{0,5:F1} MiB" -f ($B / 1MB) }
    if ($B -ge 1KB) { return "{0,5:F1} KiB" -f ($B / 1KB) }
    return            "{0,5:F0}   B" -f $B
}
 
function Make-Bar([long]$Size, [long]$Max, [int]$Width = 20) {
    if ($Max -le 0) { return " ".PadRight($Width) }
    $n = [math]::Min($Width, [int][math]::Round(($Size / $Max) * $Width))
    return ("#" * $n).PadRight($Width)
}
 
function Trunc([string]$s, [int]$n) {
    if ($n -le 0) { return "" }
    if ($s.Length -le $n) { return $s.PadRight($n) }
    return $s.Substring(0, $n - 1) + ">"
}
 
function SW { return [math]::Max(40, [Console]::WindowWidth) }
function SH { return [math]::Max(10, [Console]::WindowHeight) }
 
# ═══════════════════════════════════════════════════════════════════════════════
#  SCANNING + PROGRESS BAR
# ═══════════════════════════════════════════════════════════════════════════════
 
function Show-ScanProgress {
    param([string]$Root, [string]$CurrentItem, [int]$Done, [int]$Total)
 
    $W   = SW; $H = SH
    $bW  = [math]::Min(52, $W - 8)
    $pct = if ($Total -gt 0) { [int](($Done / $Total) * 100) } else { 0 }
    $fil = [int]($bW * $pct / 100)
    $y   = [math]::Max(1, [int]($H / 2) - 5)
 
    [Console]::Clear()
    [Console]::BackgroundColor = "Black"
 
    # Title bar
    [Console]::SetCursorPosition(0, 0)
    [Console]::BackgroundColor = "DarkCyan"; [Console]::ForegroundColor = "White"
    Write-Host "  ncdu.ps1  ~  Scanne ...".PadRight($W).Substring(0,$W) -NoNewline
    [Console]::BackgroundColor = "Black"
 
    # Root label
    [Console]::SetCursorPosition(2, $y)
    [Console]::ForegroundColor = "DarkGray"; Write-Host "Verzeichnis:"
    [Console]::SetCursorPosition(2, $y+1)
    [Console]::ForegroundColor = "White"
    $rd = if ($Root.Length -gt $W-4) { "..."+$Root.Substring($Root.Length-($W-7)) } else { $Root }
    Write-Host $rd
 
    # Current item
    [Console]::SetCursorPosition(2, $y+3)
    [Console]::ForegroundColor = "DarkGray"; Write-Host "Scanne:"
    [Console]::SetCursorPosition(2, $y+4)
    [Console]::ForegroundColor = "Cyan"
    $cd = if ($CurrentItem.Length -gt $W-4) { "..."+$CurrentItem.Substring($CurrentItem.Length-($W-7)) } else { $CurrentItem }
    $cdPad = $W - 4
    Write-Host $cd.PadRight($cdPad).Substring(0,[math]::Min($cdPad, [math]::Max(0,$cdPad)))
 
    # Progress bar
    [Console]::SetCursorPosition(2, $y+6)
    [Console]::ForegroundColor = "DarkGray";  Write-Host "[" -NoNewline
    [Console]::ForegroundColor = "Green";     Write-Host ("X" * $fil) -NoNewline
    [Console]::ForegroundColor = "DarkGray";  Write-Host ("." * ($bW - $fil) + "]  ") -NoNewline
    [Console]::ForegroundColor = "Yellow";    Write-Host "$pct%"
 
    # Item count
    [Console]::SetCursorPosition(2, $y+7)
    [Console]::ForegroundColor = "DarkGray"
    Write-Host "$Done / $Total Elemente"
}
 
function Load-Dir([string]$Path) {
    $allDirs  = @(Get-ChildItem $Path -Directory -Force -EA SilentlyContinue)
    $allFiles = @(Get-ChildItem $Path -File     -Force -EA SilentlyContinue)
    $total    = $allDirs.Count + $allFiles.Count
    $done     = 0
    $list     = [System.Collections.Generic.List[psobject]]::new()
 
    foreach ($d in $allDirs) {
        Show-ScanProgress -Root $Path -CurrentItem $d.FullName -Done $done -Total $total
        $list.Add([pscustomobject]@{ Name=$d.Name; Path=$d.FullName; Size=(Get-DirSize $d.FullName); IsDir=$true })
        $done++
    }
    foreach ($f in $allFiles) {
        Show-ScanProgress -Root $Path -CurrentItem $f.FullName -Done $done -Total $total
        $list.Add([pscustomobject]@{ Name=$f.Name; Path=$f.FullName; Size=$f.Length; IsDir=$false })
        $done++
    }
 
    return @($list | Sort-Object -Property Size -Descending)
}
 
