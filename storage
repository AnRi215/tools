function Get-DirSize([string]$Path) {
    try {
        $r = (Get-ChildItem $Path -Recurse -Force -ErrorAction SilentlyContinue |
              Where-Object { -not $_.PSIsContainer } |
              Measure-Object -Property Length -Sum).Sum
        if ($null -eq $r) { return 0L }
        return [long]$r
    } catch { return 0L }
}

function Format-Bytes([long]$B) {
    if ($B -ge 1TB) { return "{0,5:F1} TiB" -f ($B / 1TB) }
    if ($B -ge 1GB) { return "{0,5:F1} GiB" -f ($B / 1GB) }
    if ($B -ge 1MB) { return "{0,5:F1} MiB" -f ($B / 1MB) }
    if ($B -ge 1KB) { return "{0,5:F1} KiB" -f ($B / 1KB) }
    return "{0,5:F0}   B" -f $B
}

function Make-Bar([long]$Size, [long]$Max, [int]$Width) {
    if ($Max -le 0) { return (" " * $Width) }
    $n = [math]::Min($Width, [int][math]::Round(($Size / $Max) * $Width))
    return ("#" * $n).PadRight($Width)
}

function Trunc([string]$s, [int]$n) {
    if ($n -le 0) { return "" }
    if ($s.Length -le $n) { return $s.PadRight($n) }
    return $s.Substring(0, $n - 1) + ">"
}

function Clear-Console {
    [Console]::BackgroundColor = "Black"
    [Console]::ForegroundColor = "Gray"
